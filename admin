for i,v in pairs(game.Players:GetPlayers()) do
	v.Chatted:Connect(function(msg)
		if table.find(Whitelist, tostring(v.UserId)) then

			if msg:sub(1, #prefix) == prefix then
				msg = msg:sub(#prefix + 1)

				local parts = msg:split(" ")
				local cmdname = parts[1]
				local target = parts[2] or "me"
				local args = {table.unpack(parts, 3)}

				local command = cmds[cmdname]
				if not command then
					for i, cmd in pairs(cmds) do
						if table.find(cmd.Data.Aliases, cmdname) then
							command = cmd
							break
						end
					end
				end

				if command then
					--notfi(v, "Success", "Command: ".. cmdname)
					local targets = p(target, v)
					command.Data.Function(v, targets, args)
				else
					notfi(v, "Error", "Command '" .. cmdname .. "' was not found.")
				end
			else
				--notfi(v, "Error", "Incorrect prefix, prefix is: ".. prefix)
			end
		else
			return
		end
	end)
end

