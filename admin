function p(a, me)
	local ps = game.Players:GetPlayers()
	local found = {}

	if a:lower() == "me" then
		found = {me}
	elseif a:lower() == "others" then
		for i, player in ipairs(ps) do
			if player ~= me then
				table.insert(found, player)
			end
		end
	elseif a:lower() == "all" then
		found = ps
	elseif a:lower() == "random" then
		if #ps > 0 then
			found = {ps[math.random(1, #ps)]}
		end
	else
		for i, player in ipairs(ps) do
			if player.Name:lower():sub(1, #a) == a:lower() or player.DisplayName:lower():sub(1, #a) == a:lower() then
				table.insert(found, player)
			end
		end
	end

	return found
end

local function addcmd(data)
	if cmds[data.Name] then
		return
	end

	if not data.Aliases then
		data.Aliases = {}
	end

	cmds[data.Name] = {
		Data = data
	}
end

function notfi(plr, title, message, duration)
	coroutine.wrap(function()
		local s = plr:FindFirstChild("PlayerGui"):FindFirstChild("NotificationsGui")

		if not s then
			s = Instance.new("ScreenGui")
			s.Name = "NotificationsGui"
			s.Parent = plr:FindFirstChild("PlayerGui")
		end

		local n = Instance.new("Frame")
		n.Size = UDim2.new(0, 300, 0, 80)
		n.Position = UDim2.new(1, -320, 1, -100)
		n.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		n.BackgroundTransparency = 0.2
		n.BorderSizePixel = 0
		n.Parent = s

		local t = Instance.new("TextLabel")
		t.Text = title
		t.Size = UDim2.new(1, 0, 0.3, 0)
		t.TextColor3 = Color3.fromRGB(255, 255, 255)
		t.BackgroundTransparency = 1
		t.Font = Enum.Font.GothamBold
		t.TextScaled = true
		t.Parent = n

		local m = Instance.new("TextLabel")
		m.Text = message
		m.Size = UDim2.new(1, 0, 0.7, 0)
		m.Position = UDim2.new(0, 0, 0.3, 0)
		m.TextColor3 = Color3.fromRGB(200, 200, 200)
		m.BackgroundTransparency = 1
		m.Font = Enum.Font.Gotham
		m.TextScaled = true
		m.Parent = n

		n.Position = UDim2.new(1, 10, 1, -100)
		n:TweenPosition(UDim2.new(1, -320, 1, -100), "Out", "Quad", 0.5)

		task.wait(duration or 5)
		n:TweenPosition(UDim2.new(1, 10, 1, -100), "Out", "Quad", 0.5)

		task.wait(0.5)
		n:Destroy()
	end)()
end

